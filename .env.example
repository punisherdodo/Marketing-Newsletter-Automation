# NovaMind — Marketing Newsletter Automation
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to git.

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Required for AI Only Mode and Full CRM Mode.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — defaults to gpt-4o-mini if not set.
OPENAI_MODEL=gpt-4o-mini

# ── HubSpot ─────────────────────────────────────────────────────────────────
# Required for Full CRM Mode (contact sync).
# Create a Private App in HubSpot: Settings → Integrations → Private Apps
# Scopes needed: crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_ACCESS_TOKEN=

# ── SendGrid ─────────────────────────────────────────────────────────────────
# Required for real email delivery. Optional — falls back to simulation if not set.
# Get your key at: https://app.sendgrid.com/settings/api_keys
# Permission needed: Mail Send
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=you@yourdomain.com
SENDGRID_FROM_NAME=NovaMind

# ── App settings ─────────────────────────────────────────────────────────────
# Starting mode: demo | ai | full  (can also be set from the Setup tab in the UI)
APP_MODE=demo

# Path to the SQLite database file. Default: data/novamind.db
DATABASE_PATH=data/novamind.db
