# NovaMind — copy this file to .env and fill in your values
# NEVER commit your real .env file to git

# --- Required for AI Only Mode and Full CRM Mode ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Required for Full CRM Mode ---
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# --- Required for Email Delivery (optional — falls back to simulation) ---
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=you@yourdomain.com
SENDGRID_FROM_NAME=NovaMind

# --- Optional overrides ---
# OPENAI_MODEL defaults to gpt-4o-mini if not set
OPENAI_MODEL=gpt-4o-mini
